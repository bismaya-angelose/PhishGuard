{
  "manifest_version": 3,
  "name": "PhishGuard Strict",
  "version": "2.0",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["phishlist.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
